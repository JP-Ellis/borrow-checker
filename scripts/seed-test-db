    transactions.void(&voided_id).await?;

    // --- Summary ------------------------------------------------------------

    println!("Created database at {}", args.db_path.display());
    println!("Accounts created: 10");
    println!("Transactions created: 25 (22 cleared, 2 pending, 1 voided)");
