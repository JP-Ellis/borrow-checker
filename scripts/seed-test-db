                        .amount(aud(dec!(6.50)))
                        .build(),
                    Posting::builder()
                        .id(PostingId::new())
                        .account_id(credit_card_id.clone())
                        .amount(aud(dec!(-6.50)))
                        .build(),
                ])
                .build(),
        )
        .await?;

    // 19. Transport — petrol (Cleared)
    transactions
        .create(
