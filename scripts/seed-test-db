    println!("  [expense]   Expenses:Groceries");
    println!("  [expense]   Expenses:Dining");
    println!("  [expense]   Expenses:Utilities");
    println!("  [expense]   Expenses:Transport");
    println!("  [expense]   Expenses:Subscriptions");

    Ok(())
