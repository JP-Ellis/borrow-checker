        TransactionStatus::Cleared,
        &transport_id,
        dec!(50.00),
        &transport_env,
        &checking_id,
        dec!(-50.00)
    );

    // Day 3: Netflix streaming (Pending — subscription renewal)
    txn_env!(
        month_day(1, 3),
        "Netflix",
        "April streaming subscription",
        TransactionStatus::Pending,
        &subscriptions_id,
        dec!(22.99),
        &subscriptions_env,
