                        .amount(aud(dec!(88.50)))
                        .build(),
                    Posting::builder()
                        .id(PostingId::new())
                        .account_id(credit_card_id.clone())
                        .amount(aud(dec!(-88.50)))
                        .build(),
                ])
                .build(),
        )
        .await?;

    // 9. Utilities — electricity (Cleared)
    transactions
        .create(
            Transaction::builder()
                .id(TransactionId::new())
                .date(date(2026, 1, 12))
                .payee("AGL Energy")
                .description("January electricity bill")
                .status(TransactionStatus::Cleared)
                .created_at(Timestamp::now())
                .postings(vec![
                    Posting::builder()
                        .id(PostingId::new())
                        .account_id(utilities_id.clone())
                        .amount(aud(dec!(210.00)))
                        .build(),
                    Posting::builder()
                        .id(PostingId::new())
                        .account_id(checking_id.clone())
                        .amount(aud(dec!(-210.00)))
                        .build(),
                ])
                .build(),
        )
        .await?;

    // 10. Utilities — internet (Cleared)
    transactions
        .create(
            Transaction::builder()
                .id(TransactionId::new())
                .date(date(2026, 2, 12))
                .payee("Telstra")
                .description("February internet bill")
                .status(TransactionStatus::Cleared)
                .created_at(Timestamp::now())
                .postings(vec![
                    Posting::builder()
                        .id(PostingId::new())
                        .account_id(utilities_id.clone())
                        .amount(aud(dec!(89.00)))
                        .build(),
                    Posting::builder()
                        .id(PostingId::new())
                        .account_id(checking_id.clone())
                        .amount(aud(dec!(-89.00)))
                        .build(),
                ])
                .build(),
        )
        .await?;

    // 11. Transport — transit top-up (Cleared)
    transactions
        .create(
            Transaction::builder()
                .id(TransactionId::new())
                .date(date(2026, 1, 18))
                .payee("Opal Card")
                .description("Monthly transit top-up")
