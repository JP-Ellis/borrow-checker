#!/usr/bin/env -S cargo +nightly -Zscript
---
[package]
edition = "2024"

[dependencies]
anyhow             = "1"
bc-core            = { path = "../crates/bc-core" }
bc-models          = { path = "../crates/bc-models" }
clap               = { version = "4", features = ["derive"] }
jiff               = { version = "0.2", features = ["serde"] }
rust_decimal       = { version = "1", features = ["serde-with-str"] }
rust_decimal_macros = "1"
tokio              = { version = "1", features = ["rt-multi-thread", "macros"] }
---

// Seed a SQLite database with a realistic 6-month dataset for manual QA.
//
// Creates a full account hierarchy, envelope budget structure with allocations,
// and ~75 transactions covering Nov 2025 – Apr 2026.
//
// Usage:
//   cargo +nightly -Zscript scripts/seed-test-db [--db-path <PATH>] [--force]

use std::path::PathBuf;

use bc_core::AccountService;
use bc_core::EnvelopeService;
use bc_core::TransactionService;
use bc_models::AccountId;
use bc_models::AccountKind;
use bc_models::AccountType;
use bc_models::Amount;
use bc_models::CommodityCode;
use bc_models::Decimal;
use bc_models::Period;
use bc_models::Posting;
use bc_models::PostingId;
use bc_models::RolloverPolicy;
use bc_models::Transaction;
use bc_models::TransactionId;
use bc_models::TransactionStatus;
use clap::Parser;
use jiff::Timestamp;
use jiff::civil::Date;
use rust_decimal_macros::dec;

#[derive(Parser)]
#[command(name = "seed-test-db", about = "Seed a SQLite database with realistic test fixture data")]
struct Args {
    // Path where the database file will be written.
    #[arg(long, default_value = "./borrow-checker-test.db")]
    db_path: PathBuf,

    // Overwrite the database file if it already exists.
    #[arg(long)]
    force: bool,
}

fn aud(value: Decimal) -> Amount {
    Amount::new(value, CommodityCode::new("AUD"))
}

fn date(year: i16, month: i8, day: i8) -> Date {
    Date::constant(year, month, day)
}

fn posting(account_id: &AccountId, amount: Amount) -> Posting {
    Posting::builder()
        .id(PostingId::new())
        .account_id(account_id.clone())
        .amount(amount)
        .build()
}

#[tokio::main]
async fn main() -> anyhow::Result<()> {
    let args = Args::parse();

    if args.db_path.exists() && !args.force {
        anyhow::bail!(
            "database already exists at '{}'. Use --force to overwrite.",
            args.db_path.display()
        );
    }

    if args.db_path.exists() && args.force {
        std::fs::remove_file(&args.db_path)?;
    }

    let pool = bc_core::open_db_at(&args.db_path).await?;
    let accounts = AccountService::new(pool.clone());
    let envelopes = EnvelopeService::new(pool.clone());
    let transactions = TransactionService::new(pool.clone());

    // =========================================================================
    // ACCOUNTS (20 total: 5 root + 15 leaf)
    // =========================================================================

    // --- Root accounts -------------------------------------------------------

    let assets_id = accounts
        .create()
        .name("Assets")
        .account_type(AccountType::Asset)
        .kind(AccountKind::DepositAccount)
        .call()
        .await?;

    let liabilities_id = accounts
        .create()
        .name("Liabilities")
        .account_type(AccountType::Liability)
        .kind(AccountKind::DepositAccount)
        .call()
        .await?;

    let equity_id = accounts
        .create()
        .name("Equity")
        .account_type(AccountType::Equity)
        .kind(AccountKind::DepositAccount)
        .call()
        .await?;

    let income_id = accounts
        .create()
        .name("Income")
        .account_type(AccountType::Income)
        .kind(AccountKind::DepositAccount)
        .call()
        .await?;

    let expenses_id = accounts
        .create()
        .name("Expenses")
        .account_type(AccountType::Expense)
        .kind(AccountKind::DepositAccount)
        .call()
        .await?;

    // --- Asset leaf accounts -------------------------------------------------

    let checking_id = accounts
        .create()
        .name("Checking")
        .account_type(AccountType::Asset)
        .kind(AccountKind::DepositAccount)
        .parent_id(&assets_id)
        .call()
        .await?;

    let savings_id = accounts
        .create()
        .name("Savings")
        .account_type(AccountType::Asset)
        .kind(AccountKind::DepositAccount)
        .parent_id(&assets_id)
        .call()
        .await?;

    let car_id = accounts
        .create()
        .name("Car")
        .account_type(AccountType::Asset)
        .kind(AccountKind::ManualAsset)
        .parent_id(&assets_id)
        .call()
        .await?;

    // --- Liability leaf accounts ---------------------------------------------

    let credit_card_id = accounts
        .create()
        .name("CreditCard")
        .account_type(AccountType::Liability)
        .kind(AccountKind::DepositAccount)
        .parent_id(&liabilities_id)
        .call()
        .await?;

    let car_loan_id = accounts
        .create()
        .name("CarLoan")
        .account_type(AccountType::Liability)
        .kind(AccountKind::DepositAccount)
        .parent_id(&liabilities_id)
        .call()
        .await?;

    // --- Equity leaf accounts ------------------------------------------------

    let opening_balance_id = accounts
        .create()
        .name("OpeningBalance")
        .account_type(AccountType::Equity)
        .kind(AccountKind::DepositAccount)
        .parent_id(&equity_id)
        .call()
        .await?;

    // --- Income leaf accounts ------------------------------------------------

    let salary_id = accounts
        .create()
        .name("Salary")
        .account_type(AccountType::Income)
        .kind(AccountKind::DepositAccount)
        .parent_id(&income_id)
        .call()
        .await?;

    let interest_id = accounts
        .create()
        .name("Interest")
        .account_type(AccountType::Income)
        .kind(AccountKind::DepositAccount)
        .parent_id(&income_id)
        .call()
        .await?;

    let freelance_id = accounts
        .create()
        .name("Freelance")
        .account_type(AccountType::Income)
        .kind(AccountKind::DepositAccount)
        .parent_id(&income_id)
        .call()
        .await?;

    // --- Expense leaf accounts -----------------------------------------------

    let groceries_id = accounts
        .create()
        .name("Groceries")
        .account_type(AccountType::Expense)
        .kind(AccountKind::DepositAccount)
        .parent_id(&expenses_id)
        .call()
        .await?;

    let dining_id = accounts
        .create()
        .name("Dining")
        .account_type(AccountType::Expense)
        .kind(AccountKind::DepositAccount)
        .parent_id(&expenses_id)
        .call()
        .await?;

    let utilities_id = accounts
        .create()
        .name("Utilities")
        .account_type(AccountType::Expense)
        .kind(AccountKind::DepositAccount)
        .parent_id(&expenses_id)
        .call()
        .await?;

    let transport_id = accounts
        .create()
        .name("Transport")
        .account_type(AccountType::Expense)
        .kind(AccountKind::DepositAccount)
        .parent_id(&expenses_id)
        .call()
        .await?;

    let subscriptions_id = accounts
        .create()
        .name("Subscriptions")
        .account_type(AccountType::Expense)
        .kind(AccountKind::DepositAccount)
        .parent_id(&expenses_id)
        .call()
        .await?;

    let healthcare_id = accounts
        .create()
        .name("Healthcare")
        .account_type(AccountType::Expense)
        .kind(AccountKind::DepositAccount)
        .parent_id(&expenses_id)
        .call()
        .await?;

    let entertainment_id = accounts
        .create()
        .name("Entertainment")
        .account_type(AccountType::Expense)
        .kind(AccountKind::DepositAccount)
        .parent_id(&expenses_id)
        .call()
        .await?;

    // Silence unused-variable warnings for root accounts only used as parents.
    let _ = &income_id;
    let _ = &liabilities_id;
    let _ = &equity_id;
    let _ = &car_id;

    // =========================================================================
    // ENVELOPES (10 total: 3 root + 7 leaf)
    // =========================================================================

    // --- Root envelopes ------------------------------------------------------

    let living_env = envelopes
        .create()
        .name("Living")
        .period(Period::Monthly)
        .rollover_policy(RolloverPolicy::ResetToZero)
        .call()
        .await?;

    let discretionary_env = envelopes
        .create()
        .name("Discretionary")
        .period(Period::Monthly)
        .rollover_policy(RolloverPolicy::ResetToZero)
        .call()
        .await?;

    let health_env = envelopes
        .create()
        .name("Health")
        .period(Period::Monthly)
        .rollover_policy(RolloverPolicy::ResetToZero)
        .call()
        .await?;

    // --- Living leaf envelopes -----------------------------------------------

    let groceries_env = envelopes
        .create()
        .name("Groceries")
        .parent_id(living_env.id().clone())
        .period(Period::Monthly)
        .rollover_policy(RolloverPolicy::ResetToZero)
        .call()
        .await?;

    let utilities_env = envelopes
        .create()
        .name("Utilities")
        .parent_id(living_env.id().clone())
        .period(Period::Monthly)
        .rollover_policy(RolloverPolicy::ResetToZero)
        .call()
        .await?;

    let transport_env = envelopes
        .create()
        .name("Transport")
        .parent_id(living_env.id().clone())
        .period(Period::Monthly)
        .rollover_policy(RolloverPolicy::ResetToZero)
        .call()
        .await?;

    // --- Discretionary leaf envelopes ----------------------------------------

    let dining_env = envelopes
        .create()
        .name("Dining")
        .parent_id(discretionary_env.id().clone())
        .period(Period::Monthly)
        .rollover_policy(RolloverPolicy::ResetToZero)
        .call()
        .await?;

    let entertainment_env = envelopes
        .create()
        .name("Entertainment")
        .parent_id(discretionary_env.id().clone())
        .period(Period::Monthly)
        .rollover_policy(RolloverPolicy::ResetToZero)
        .call()
        .await?;

    let subscriptions_env = envelopes
        .create()
        .name("Subscriptions")
        .parent_id(discretionary_env.id().clone())
        .period(Period::Monthly)
        .rollover_policy(RolloverPolicy::ResetToZero)
        .call()
        .await?;

    // --- Health leaf envelopes -----------------------------------------------

    let healthcare_env = envelopes
        .create()
        .name("Healthcare")
        .parent_id(health_env.id().clone())
        .period(Period::Monthly)
        .rollover_policy(RolloverPolicy::ResetToZero)
        .call()
        .await?;

    // Silence unused-variable warnings for root envelopes only used as parents.
    let _ = &living_env;
    let _ = &discretionary_env;
    let _ = &health_env;

    // =========================================================================
    // ALLOCATIONS (42 total: 7 leaf envelopes × 6 months)
    // =========================================================================

    // Monthly allocation amounts:
    //   Groceries:     600/mo
    //   Utilities:     350/mo
    //   Transport:     200/mo
    //   Dining:        300/mo
    //   Entertainment: 150/mo
    //   Subscriptions:  60/mo
    //   Healthcare:    200/mo

    let months: [(i16, i8); 6] = [
        (2025, 11),
        (2025, 12),
        (2026, 1),
        (2026, 2),
        (2026, 3),
        (2026, 4),
    ];

    for (year, month) in months {
        let period_start = date(year, month, 1);
        envelopes
            .allocate(groceries_env.id(), period_start, aud(dec!(600.00)))
            .await?;
        envelopes
            .allocate(utilities_env.id(), period_start, aud(dec!(350.00)))
            .await?;
        envelopes
            .allocate(transport_env.id(), period_start, aud(dec!(200.00)))
            .await?;
        envelopes
            .allocate(dining_env.id(), period_start, aud(dec!(300.00)))
            .await?;
        envelopes
            .allocate(entertainment_env.id(), period_start, aud(dec!(150.00)))
            .await?;
        envelopes
            .allocate(subscriptions_env.id(), period_start, aud(dec!(60.00)))
            .await?;
        envelopes
            .allocate(healthcare_env.id(), period_start, aud(dec!(200.00)))
            .await?;
    }

    // =========================================================================
    // TRANSACTIONS (~75 total across Nov 2025 – Apr 2026)
    // =========================================================================

    // Helper macro to reduce boilerplate for simple two-posting transactions.
    macro_rules! txn {
        ($date:expr, $payee:expr, $desc:expr, $status:expr,
         $debit_acct:expr, $debit_amt:expr,
         $credit_acct:expr, $credit_amt:expr) => {
            transactions
                .create(
                    Transaction::builder()
                        .id(TransactionId::new())
                        .date($date)
                        .payee($payee)
                        .description($desc)
                        .status($status)
                        .created_at(Timestamp::now())
                        .postings(vec![
                            posting($debit_acct, aud($debit_amt)),
                            posting($credit_acct, aud($credit_amt)),
                        ])
                        .build(),
                )
                .await?
        };
    }

    // -------------------------------------------------------------------------
    // Opening balances (Nov 1, 2025)
    // -------------------------------------------------------------------------

    // Checking: 3500 opening balance
    txn!(
        date(2025, 11, 1),
        "Opening Balance",
        "Checking opening balance",
        TransactionStatus::Cleared,
        &checking_id,
        dec!(3500.00),
        &opening_balance_id,
        dec!(-3500.00)
    );

    // Savings: 8000 opening balance
    txn!(
        date(2025, 11, 1),
        "Opening Balance",
        "Savings opening balance",
        TransactionStatus::Cleared,
        &savings_id,
        dec!(8000.00),
        &opening_balance_id,
        dec!(-8000.00)
    );

    // CreditCard liability: -450 opening balance (liability has credit balance)
    txn!(
        date(2025, 11, 1),
        "Opening Balance",
        "Credit card opening balance",
        TransactionStatus::Cleared,
        &opening_balance_id,
        dec!(450.00),
        &credit_card_id,
        dec!(-450.00)
    );

    // CarLoan liability: -12000 opening balance
    txn!(
        date(2025, 11, 1),
        "Opening Balance",
        "Car loan opening balance",
        TransactionStatus::Cleared,
        &opening_balance_id,
        dec!(12000.00),
        &car_loan_id,
        dec!(-12000.00)
    );

    // -------------------------------------------------------------------------
    // November 2025
    // -------------------------------------------------------------------------

    // Nov 5: Freelance income
    txn!(
        date(2025, 11, 5),
        "Client A",
        "November freelance payment",
        TransactionStatus::Cleared,
        &checking_id,
        dec!(800.00),
        &freelance_id,
        dec!(-800.00)
    );

    // Nov 15: Paycheck
    txn!(
        date(2025, 11, 15),
        "Employer Ltd",
        "November paycheck",
        TransactionStatus::Cleared,
        &checking_id,
        dec!(5200.00),
        &salary_id,
        dec!(-5200.00)
    );

    // Nov 20: Credit card payment
    txn!(
        date(2025, 11, 20),
        "Visa",
        "November credit card payment",
        TransactionStatus::Cleared,
        &credit_card_id,
        dec!(800.00),
        &checking_id,
        dec!(-800.00)
    );

    // Nov 25: Savings transfer
    txn!(
        date(2025, 11, 25),
        "Transfer",
        "November savings transfer",
        TransactionStatus::Cleared,
        &savings_id,
        dec!(1000.00),
        &checking_id,
        dec!(-1000.00)
    );

    // Nov 30: Savings interest
    txn!(
        date(2025, 11, 30),
        "Bank",
        "November savings interest",
        TransactionStatus::Cleared,
        &savings_id,
        dec!(9.50),
        &interest_id,
        dec!(-9.50)
    );

    // Nov 1: Car loan repayment
    txn!(
        date(2025, 11, 1),
        "Car Finance",
        "November car loan repayment",
        TransactionStatus::Cleared,
        &car_loan_id,
        dec!(350.00),
        &checking_id,
        dec!(-350.00)
    );

    // Nov 3: Woolworths groceries
    txn!(
        date(2025, 11, 3),
        "Woolworths",
        "November groceries",
        TransactionStatus::Cleared,
        &groceries_id,
        dec!(140.00),
        &credit_card_id,
        dec!(-140.00)
    );

    // Nov 14: Coles groceries
    txn!(
        date(2025, 11, 14),
        "Coles",
        "November fortnightly groceries",
        TransactionStatus::Cleared,
        &groceries_id,
        dec!(110.00),
        &credit_card_id,
        dec!(-110.00)
    );

    // Nov 22: IGA top-up
    txn!(
        date(2025, 11, 22),
        "IGA",
        "November grocery top-up",
        TransactionStatus::Cleared,
        &groceries_id,
        dec!(55.00),
        &credit_card_id,
        dec!(-55.00)
    );

    // Nov 8: Restaurant dining
    txn!(
        date(2025, 11, 8),
        "The Local Bistro",
        "November dinner",
        TransactionStatus::Cleared,
        &dining_id,
        dec!(85.00),
        &credit_card_id,
        dec!(-85.00)
    );

    // Nov 20: Café coffee
    txn!(
        date(2025, 11, 20),
        "The Coffee Club",
        "November coffee",
        TransactionStatus::Cleared,
        &dining_id,
        dec!(18.50),
        &credit_card_id,
        dec!(-18.50)
    );

    // Nov 12: AGL electricity
    txn!(
        date(2025, 11, 12),
        "AGL Energy",
        "November electricity bill",
        TransactionStatus::Cleared,
        &utilities_id,
        dec!(210.00),
        &checking_id,
        dec!(-210.00)
    );

    // Nov 12: Telstra internet
    txn!(
        date(2025, 11, 12),
        "Telstra",
        "November internet bill",
        TransactionStatus::Cleared,
        &utilities_id,
        dec!(89.00),
        &checking_id,
        dec!(-89.00)
    );

    // Nov 28: Origin Energy gas bill (November extra)
    txn!(
        date(2025, 11, 28),
        "Origin Energy",
        "November gas bill",
        TransactionStatus::Cleared,
        &utilities_id,
        dec!(130.00),
        &checking_id,
        dec!(-130.00)
    );

    // Nov 18: Opal card transit
    txn!(
        date(2025, 11, 18),
        "Opal Card",
        "November transit top-up",
        TransactionStatus::Cleared,
        &transport_id,
        dec!(50.00),
        &checking_id,
        dec!(-50.00)
    );

    // Nov 3: Netflix streaming
    txn!(
        date(2025, 11, 3),
        "Netflix",
        "November streaming subscription",
        TransactionStatus::Cleared,
        &subscriptions_id,
        dec!(22.99),
        &credit_card_id,
        dec!(-22.99)
    );

    // Nov 3: Spotify music
    txn!(
        date(2025, 11, 3),
        "Spotify",
        "November music subscription",
        TransactionStatus::Cleared,
        &subscriptions_id,
        dec!(12.99),
        &credit_card_id,
        dec!(-12.99)
    );

    // Nov 10: iCloud storage
    txn!(
        date(2025, 11, 10),
        "iCloud",
        "November cloud storage",
        TransactionStatus::Cleared,
        &subscriptions_id,
        dec!(4.49),
        &credit_card_id,
        dec!(-4.49)
    );

    // -------------------------------------------------------------------------
    // December 2025
    // -------------------------------------------------------------------------

    // Dec 15: Paycheck
    txn!(
        date(2025, 12, 15),
        "Employer Ltd",
        "December paycheck",
        TransactionStatus::Cleared,
        &checking_id,
        dec!(5200.00),
        &salary_id,
        dec!(-5200.00)
    );

    // Dec 20: Credit card payment
    txn!(
        date(2025, 12, 20),
        "Visa",
        "December credit card payment",
        TransactionStatus::Cleared,
        &credit_card_id,
        dec!(800.00),
        &checking_id,
        dec!(-800.00)
    );

    // Dec 25: Savings transfer
    txn!(
        date(2025, 12, 25),
        "Transfer",
        "December savings transfer",
        TransactionStatus::Cleared,
        &savings_id,
        dec!(1000.00),
        &checking_id,
        dec!(-1000.00)
    );

    // Dec 31: Savings interest
    txn!(
        date(2025, 12, 31),
        "Bank",
        "December savings interest",
        TransactionStatus::Cleared,
        &savings_id,
        dec!(10.00),
        &interest_id,
        dec!(-10.00)
    );

    // Dec 1: Car loan repayment
    txn!(
        date(2025, 12, 1),
        "Car Finance",
        "December car loan repayment",
        TransactionStatus::Cleared,
        &car_loan_id,
        dec!(350.00),
        &checking_id,
        dec!(-350.00)
    );

    // Dec 3: Woolworths groceries
    txn!(
        date(2025, 12, 3),
        "Woolworths",
        "December groceries",
        TransactionStatus::Cleared,
        &groceries_id,
        dec!(140.00),
        &credit_card_id,
        dec!(-140.00)
    );

    // Dec 14: Coles groceries
    txn!(
        date(2025, 12, 14),
        "Coles",
        "December fortnightly groceries",
        TransactionStatus::Cleared,
        &groceries_id,
        dec!(110.00),
        &credit_card_id,
        dec!(-110.00)
    );

    // Dec 22: IGA top-up
    txn!(
        date(2025, 12, 22),
        "IGA",
        "December grocery top-up",
        TransactionStatus::Cleared,
        &groceries_id,
        dec!(55.00),
        &credit_card_id,
        dec!(-55.00)
    );

    // Dec 8: Restaurant dining
    txn!(
        date(2025, 12, 8),
        "The Local Bistro",
        "December dinner",
        TransactionStatus::Cleared,
        &dining_id,
        dec!(85.00),
        &credit_card_id,
        dec!(-85.00)
    );

    // Dec 20: Café coffee
    txn!(
        date(2025, 12, 20),
        "The Coffee Club",
        "December coffee",
        TransactionStatus::Cleared,
        &dining_id,
        dec!(18.50),
        &credit_card_id,
        dec!(-18.50)
    );

    // Dec 22: Christmas dinner (December extra)
    txn!(
        date(2025, 12, 22),
        "Fine Dining Co",
        "Christmas dinner",
        TransactionStatus::Cleared,
        &dining_id,
        dec!(210.00),
        &credit_card_id,
        dec!(-210.00)
    );

    // Dec 31: NYE dinner (December extra)
    txn!(
        date(2025, 12, 31),
        "NYE Restaurant",
        "New Year's Eve dinner",
        TransactionStatus::Cleared,
        &dining_id,
        dec!(175.00),
        &credit_card_id,
        dec!(-175.00)
    );

    // Dec 12: AGL electricity
    txn!(
        date(2025, 12, 12),
        "AGL Energy",
        "December electricity bill",
        TransactionStatus::Cleared,
        &utilities_id,
        dec!(210.00),
        &checking_id,
        dec!(-210.00)
    );

    // Dec 12: Telstra internet
    txn!(
        date(2025, 12, 12),
        "Telstra",
        "December internet bill",
        TransactionStatus::Cleared,
        &utilities_id,
        dec!(89.00),
        &checking_id,
        dec!(-89.00)
    );

    // Dec 18: Opal card transit
    txn!(
        date(2025, 12, 18),
        "Opal Card",
        "December transit top-up",
        TransactionStatus::Cleared,
        &transport_id,
        dec!(50.00),
        &checking_id,
        dec!(-50.00)
    );

    // Dec 3: Netflix streaming
    txn!(
        date(2025, 12, 3),
        "Netflix",
        "December streaming subscription",
        TransactionStatus::Cleared,
        &subscriptions_id,
        dec!(22.99),
        &credit_card_id,
        dec!(-22.99)
    );

    // Dec 3: Spotify music
    txn!(
        date(2025, 12, 3),
        "Spotify",
        "December music subscription",
        TransactionStatus::Cleared,
        &subscriptions_id,
        dec!(12.99),
        &credit_card_id,
        dec!(-12.99)
    );

