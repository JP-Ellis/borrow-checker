        dec!(-18.50)
    );

    // Day 12: AGL electricity
    txn_env!(
        month_day(1, 12),
        "AGL Energy",
        "April electricity bill",
        TransactionStatus::Cleared,
        &electricity_id,
        dec!(210.00),
        &utilities_env,
        &checking_id,
        dec!(-210.00)
    );

    // Day 12: Telstra internet (drinking water)
    txn_env!(
