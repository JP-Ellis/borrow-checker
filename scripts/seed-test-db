        &groceries_env,
        &credit_card_id,
        dec!(-110.00)
    );

    // Day 22: IGA top-up
    txn_env!(
        month_day(1, 22),
        "IGA",
        "April grocery top-up",
        TransactionStatus::Cleared,
        &groceries_id,
        dec!(55.00),
        &groceries_env,
        &credit_card_id,
        dec!(-55.00)
    );

    // Day 8: Restaurant dining (Pending — last dining entry)
    txn_env!(
        month_day(1, 8),
        "The Local Bistro",
        "April dinner",
        TransactionStatus::Pending,
        &dining_id,
        dec!(85.00),
        &dining_env,
